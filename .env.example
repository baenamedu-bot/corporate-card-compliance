# --- Supabase (필수) ---
# Vercel Dashboard → Settings → Environment Variables 에 등록하세요.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Gemini (BYOK, 환경변수 불필요) ---
# Gemini API 키는 .env 가 아닌 앱 우측 상단 ⚙️ 버튼 → API 키 설정 모달에서 입력하세요.
# 키는 사용자의 브라우저 localStorage 에만 저장되며 서버로 전송되지 않습니다.
