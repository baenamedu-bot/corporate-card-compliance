# --- Supabase ---
# 클라이언트 노출 가능 (anon key). Vercel Dashboard → Settings → Environment Variables 에 등록.
# service role key 는 절대 여기/클라이언트/git 에 두지 말 것.
NEXT_PUBLIC_SUPABASE_URL=https://cnrgitudyobqbointtop.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Gemini ---
# 이 앱은 BYOK(Bring Your Own Key) 방식입니다.
# Gemini API 키는 .env 가 아닌 앱 우측 상단 ⚙️ 버튼 → API 키 설정 모달에서 입력하세요.
# 키는 사용자의 브라우저 localStorage 에만 저장되며 서버로 전송되지 않습니다.
